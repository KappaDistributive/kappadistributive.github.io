    <span class="n">query</span><span class="p">:</span> <span class="nb">str</span><span class="p">,</span>
    <span class="n">query_parameters</span><span class="p">:</span> <span class="n">List</span><span class="p">[</span><span class="n">QueryParameter</span><span class="p">],</span>
    <span class="n">cache_location</span><span class="p">:</span> <span class="n">Path</span><span class="p">,</span>
